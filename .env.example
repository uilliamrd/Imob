# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Site
NEXT_PUBLIC_SITE_URL=https://seu-dominio.vercel.app

# Asaas (pagamentos)
ASAAS_API_KEY=
ASAAS_SANDBOX=true
ASAAS_WEBHOOK_TOKEN=seu_token_secreto_aqui  # Obrigatório — veja em Asaas > Integrações > Webhooks

# OpenAI
OPENAI_API_KEY=

# Ingestão de dados
API_INGEST_TOKEN=

# Testes de segurança (integration tests — não usar dados reais)
TEST_USER_A_EMAIL=usuario-teste-a@sua-empresa.com
TEST_USER_A_PASSWORD=senha-teste-a
TEST_USER_B_EMAIL=usuario-teste-b@outra-empresa.com
TEST_USER_B_PASSWORD=senha-teste-b

# Sentry (monitoramento de erros)
# DSN disponível em: sentry.io → seu projeto → Settings → Client Keys
SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
# Org e projeto: sentry.io → Settings → General Settings
SENTRY_ORG=sua-organizacao
SENTRY_PROJECT=realstate-intelligence
# Token para upload de source maps em CI/CD: sentry.io → Settings → Auth Tokens
SENTRY_AUTH_TOKEN=sntrys_xxxx
